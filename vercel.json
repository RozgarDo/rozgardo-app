{
  "version": 2,
  "name": "rozgardo",
  "rewrites": [
    {
      "source": "/_/backend/:path*",
      "destination": "/backend/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ],
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/api/*.js",
      "use": "@vercel/node"
    }
  ]
}
